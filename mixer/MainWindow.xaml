<Window x:Class="mixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:mixer.ViewModels;assembly=mixer"
        xmlns:views="clr-namespace:mixer.Views"
        Title="mixer" Height="620" Width="920" MinHeight="420" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgWindow}" Foreground="{DynamicResource TextPrimary}"
        FontFamily="Segoe UI Variable, Segoe UI">
    <Window.InputBindings>
        <KeyBinding Key="M" Modifiers="Ctrl" Command="{Binding MuteAllCommand}"/>
        <KeyBinding Key="U" Modifiers="Ctrl" Command="{Binding UnmuteAllCommand}"/>
    </Window.InputBindings>
    <Window.Resources>
        <views:VuHeightConverter x:Key="VuHeightConverter"/>
        <views:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <views:InvertBoolConverter x:Key="InvertBoolConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════ Title Bar ═══════ -->
        <DockPanel Grid.Row="0" Margin="0,0,0,18">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="mixer" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"/>
                <TextBlock Text="audio routing" FontSize="22" FontWeight="Light"
                           Foreground="{DynamicResource TextSecondary}" Margin="10,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="{DynamicResource App.Settings}" Command="{Binding OpenSettingsCommand}"
                        Height="28" FontSize="11" Margin="0,0,12,0" Padding="12,0"
                        Foreground="{DynamicResource TextSecondary}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="{DynamicResource BgPanel}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource BgElevated}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="{DynamicResource Btn.UnmuteAll}" Command="{Binding UnmuteAllCommand}"
                        Height="28" FontSize="11" Margin="0,0,6,0" Padding="12,0"
                        Foreground="{DynamicResource TextSecondary}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="{DynamicResource BgPanel}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource BgElevated}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="{DynamicResource Btn.MuteAll}" Command="{Binding MuteAllCommand}"
                        Height="28" FontSize="11" Margin="0,0,12,0" Padding="12,0"
                        Foreground="#FFF" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="#D93128" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E7483F"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="{Binding FocusedAppText}" Foreground="{DynamicResource AccentBrush}"
                           FontSize="11" Margin="0,0,12,0" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding MicInfoText}" Foreground="{DynamicResource TextSecondary}"
                           FontSize="11" Margin="0,0,12,0" TextTrimming="CharacterEllipsis"/>
                <Grid Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#E7483F"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#6CCB5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </Grid>
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
            </StackPanel>
        </DockPanel>

        <!-- ═══════ Mix Column Headers ═══════ -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"                        Text="{DynamicResource Label.Source}" Foreground="{DynamicResource TextSecondary}"
                       FontSize="10" FontWeight="SemiBold" VerticalAlignment="Bottom"
                       Margin="10,0,0,4"/>

            <ItemsControl Grid.Column="1" ItemsSource="{Binding Mixes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource BgPanel}" CornerRadius="6" Padding="4" Margin="3">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Name}" HorizontalAlignment="Center"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,0,0,5"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <ToggleButton Style="{DynamicResource MuteToggleButton}"
                                                  Content="MUTE"
                                                  IsChecked="{Binding IsMuted, Mode=TwoWay}"
                                                  Width="46" Height="22"/>
                                    <Button Style="{DynamicResource IconButton}"
                                            Content="✎" FontSize="10" Command="{Binding EditCommand}"
                                            ToolTip="MIDI Learn for this mix mute"
                                            Margin="4,0,0,0" Width="20" Height="20"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- ═══════ Source Rows ═══════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Sources}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource BgPanel}" CornerRadius="8"
                                Margin="0,0,0,8" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Source Info -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="4,0,14,0">
                                    <DockPanel>
                                        <ToggleButton DockPanel.Dock="Right"
                                                      Style="{DynamicResource MuteToggleButton}"
                                                      Content="MUTE"
                                                      IsChecked="{Binding IsMuted, Mode=TwoWay}"/>
                                        <Button DockPanel.Dock="Right" Style="{DynamicResource IconButton}"
                                                Content="✎" FontSize="10" Command="{Binding EditCommand}"
                                                ToolTip="MIDI Learn for master volume/mute"
                                                Margin="0,0,6,0" Width="20" Height="20"/>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Grid Width="3" Height="16" Margin="1,0">
                                                <Border Background="#3A3A3A" CornerRadius="1.5"/>
                                                <Border VerticalAlignment="Bottom" CornerRadius="1.5"
                                                        Height="{Binding VuLeft, Converter={StaticResource VuHeightConverter}}"
                                                        Background="{DynamicResource AccentBrush}"/>
                                            </Grid>
                                            <Grid Width="3" Height="16" Margin="1,0">
                                                <Border Background="#3A3A3A" CornerRadius="1.5"/>
                                                <Border VerticalAlignment="Bottom" CornerRadius="1.5"
                                                        Height="{Binding VuRight, Converter={StaticResource VuHeightConverter}}"
                                                        Background="{DynamicResource AccentBrush}"/>
                                            </Grid>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                    <Slider Style="{DynamicResource ModernHorizontalSlider}" Margin="0,10,0,0"
                                            Value="{Binding MasterVolume, Mode=TwoWay}"/>
                                </StackPanel>

                                <!-- Send Level Cells -->
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BgCell}" CornerRadius="8"
                                                    Margin="4" Padding="8,8">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Not Routed: Add to Mix -->
                                                    <Button Grid.Row="0"
                                                            Command="{Binding AddToMixCommand}"
                                                            Visibility="{Binding IsRouted, Converter={StaticResource InvertBoolConverter}}"
                                                            Height="28">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="bg" Background="Transparent"
                                                                        CornerRadius="6" Padding="8,4">
                                                                    <TextBlock Text="+ Add to mix" FontSize="10"
                                                                               Foreground="{DynamicResource AccentBrush}"
                                                                               HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="bg" Property="Background"
                                                                                Value="{DynamicResource BgCellHover}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>

                                                    <!-- Routed: Slider + Controls -->
                                                    <Grid Grid.Row="1"
                                                          Visibility="{Binding IsRouted, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <ToggleButton Grid.Column="0"
                                                                      Style="{DynamicResource MuteToggleButton}"
                                                                      Content="M" Width="28" Height="22"
                                                                      IsChecked="{Binding IsMuted, Mode=TwoWay}"
                                                                      ToolTip="Mute this send" Margin="0,0,8,0"/>

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Volume, StringFormat={}{0:0}%}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource TextSecondary}"
                                                                       VerticalAlignment="Center"/>
                                                            <Slider Style="{DynamicResource ModernHorizontalSlider}"
                                                                    Margin="0,4,0,0"
                                                                    Value="{Binding Volume, Mode=TwoWay}"/>
                                                        </StackPanel>

                                                        <Button Grid.Column="2"
                                                                Style="{DynamicResource IconButton}"
                                                                Content="✎" FontSize="12"
                                                                Command="{Binding EditCommand}"
                                                                ToolTip="Edit MIDI mapping for this cell"
                                                                Margin="8,0,0,0"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
