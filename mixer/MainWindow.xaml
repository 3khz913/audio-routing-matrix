<Window x:Class="mixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:mixer.ViewModels;assembly=mixer"
        Title="mixer" Height="620" Width="920" MinHeight="420" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="#1A1B1E" Foreground="#F2F2F3"
        FontFamily="Segoe UI">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title / status bar -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Audio Routing Matrix" FontSize="20" FontWeight="Bold" DockPanel.Dock="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#E74C3C"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="#2ECC71"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
            </StackPanel>
        </DockPanel>

        <!-- Column headers: mixes -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="SOURCE" Foreground="{StaticResource TextSecondary}"
                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="8,0,0,4"/>

            <ItemsControl Grid.Column="1" ItemsSource="{Binding Mixes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- قالب المزيج مع اسم وزر كتم -->
                        <Border Background="{StaticResource BgPanel}" CornerRadius="4" Padding="4" Margin="2">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Name}" HorizontalAlignment="Center"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,0,0,4"/>
                                <ToggleButton Style="{StaticResource MuteToggleButton}"
                                              Content="MUTE"
                                              IsChecked="{Binding IsMuted, Mode=TwoWay}"
                                              Width="50" Height="20" FontSize="9"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Rows: sources x cells -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Sources}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BgPanel}" CornerRadius="8" Margin="0,0,0,8" Padding="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Source info: name, master volume, mute -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="4,0,12,0">
                                    <DockPanel>
                                        <ToggleButton DockPanel.Dock="Right" Style="{StaticResource MuteToggleButton}"
                                                      Content="MUTE" IsChecked="{Binding IsMuted, Mode=TwoWay}"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                    <Slider Style="{StaticResource ModernHorizontalSlider}" Margin="0,8,0,0"
                                            Value="{Binding MasterVolume, Mode=TwoWay}"/>
                                </StackPanel>

                                <!-- Send-level cells, one per mix -->
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource BgCell}" CornerRadius="6" Margin="4" Padding="8,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- زر كتم الخلية (يسار) -->
                                                    <ToggleButton Grid.Column="0"
                                                                  Style="{StaticResource MuteToggleButton}"
                                                                  Content="M" Width="28" Height="20" FontSize="9"
                                                                  IsChecked="{Binding IsMuted, Mode=TwoWay}"
                                                                  ToolTip="Mute this send" Margin="0,0,6,0"/>

                                                    <!-- شريط الصوت والنسبة (وسط) -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Volume, StringFormat={}{0:0}%}"
                                                                   FontSize="11" Foreground="{StaticResource TextSecondary}"
                                                                   VerticalAlignment="Center"/>
                                                        <Slider Style="{StaticResource ModernHorizontalSlider}" Margin="0,6,0,0"
                                                                Value="{Binding Volume, Mode=TwoWay}"/>
                                                    </StackPanel>

                                                    <!-- زر التعديل (يمين) -->
                                                    <Button Grid.Column="2" Style="{StaticResource IconButton}"
                                                            Content="✎" FontSize="12" Command="{Binding EditCommand}"
                                                            ToolTip="Edit MIDI mapping for this cell"
                                                            Margin="6,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>