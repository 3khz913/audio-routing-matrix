<Window x:Class="mixer.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:mixer.ViewModels"
        Title="Settings" Height="380" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgWindow}" Foreground="{DynamicResource TextPrimary}"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Window.Resources>
        <Style x:Key="SettingGroup" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Settings" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,18"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Language -->
            <Border Style="{DynamicResource SettingGroup}">
                <StackPanel>
                    <TextBlock Style="{DynamicResource SettingLabel}" Text="Language / اللغة"/>
                    <ComboBox ItemsSource="{Binding Languages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              DisplayMemberPath="Name"
                              Height="32"/>
                </StackPanel>
            </Border>

            <!-- Theme -->
            <Border Style="{DynamicResource SettingGroup}">
                <StackPanel>
                    <TextBlock Style="{DynamicResource SettingLabel}" Text="Theme / المظهر"/>
                    <ComboBox ItemsSource="{Binding Themes}"
                              SelectedItem="{Binding SelectedTheme}"
                              DisplayMemberPath="Name"
                              Height="32"/>
                </StackPanel>
            </Border>

            <!-- Startup -->
            <Border Style="{DynamicResource SettingGroup}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{DynamicResource SettingLabel}"
                                   Text="Run on startup / تشغيل مع بدء النظام"/>
                        <TextBlock Text="Automatically start mixer when you sign in"
                                   FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding RunOnStartup}"
                              VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>
            </Border>
        </StackPanel>
        </ScrollViewer>

        <!-- Close -->
        <Button Grid.Row="2" Content="Close / إغلاق" Command="{Binding CloseCommand}"
                Height="34" FontSize="13" Margin="0,8,0,0"
                Foreground="White" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{DynamicResource AccentBrushStrong}" CornerRadius="8"
                            Padding="20,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
