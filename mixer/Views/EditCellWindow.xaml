<Window x:Class="mixer.Views.EditCellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:mixer.ViewModels"
        Title="{Binding Title}" Height="500" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A1B1E" Foreground="#F2F2F3"
        FontFamily="Segoe UI"
        Closed="Window_Closed">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        </Style>

        <Style x:Key="LearnButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLearning}" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Title -->
            <RowDefinition Height="Auto"/>
            <!-- 1: Device & Learn -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Control Type & Action -->
            <RowDefinition Height="*"/>
            <!-- 3: Mappings List -->
            <RowDefinition Height="Auto"/>
            <!-- 4: Close Button -->
        </Grid.RowDefinitions>

        <!-- 0: Title -->
        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- 1: Device & Learn -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="MIDI Device:" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
            <ComboBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding AvailableDevices}"
                      SelectedItem="{Binding SelectedDevice}"
                      Background="#404040" Foreground="White"
                      BorderBrush="#555555" Height="28" Margin="0,0,10,0"/>

            <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Content="Learn" Command="{Binding StartLearnCommand}"
                        Style="{StaticResource LearnButtonStyle}" Width="70" Margin="0,0,5,0"/>
                <Button Content="Delete" Command="{Binding DeleteMappingCommand}"
                        Style="{StaticResource DangerButtonStyle}" Width="70"/>
            </StackPanel>
        </Grid>

        <!-- 2: Control Type & Action -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Control Type:" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
            <ComboBox Grid.Row="1" Grid.Column="0"
                      ItemsSource="{Binding ControlTypes}"
                      SelectedItem="{Binding SelectedControlType}"
                      Background="#404040" Foreground="White"
                      BorderBrush="#555555" Height="28"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="Action:" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
            <ComboBox Grid.Row="1" Grid.Column="2"
                      ItemsSource="{Binding Actions}"
                      SelectedItem="{Binding SelectedAction}"
                      Background="#404040" Foreground="White"
                      BorderBrush="#555555" Height="28"/>
        </Grid>

        <!-- 3: Mappings List -->
        <Border Grid.Row="3" Background="#232428" CornerRadius="6" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Current Mappings:" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,6"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding Mappings}"
                         SelectedItem="{Binding SelectedMapping, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayText}" Margin="4,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 4: Learn Status & Close Button -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding LearnStatus}"
                       Foreground="{StaticResource AccentBrush}" FontSize="12"
                       VerticalAlignment="Center" TextWrapping="Wrap"/>

            <Button Grid.Column="1" Content="Close" Click="OnCloseClicked"
                    Style="{StaticResource ActionButtonStyle}" Width="80"/>
        </Grid>
    </Grid>
</Window>